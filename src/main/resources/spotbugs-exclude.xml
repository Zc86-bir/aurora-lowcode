<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- ================================================================== -->
    <!-- Exclude test classes from SpotBugs analysis                        -->
    <!-- ================================================================== -->
    <Match>
        <Class name="~.*Test"/>
    </Match>
    <Match>
        <Class name="~.*Tests"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Exclude Lombok-generated code                                      -->
    <!-- ================================================================== -->
    <Match>
        <Package name="~.*generated.*"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Exclude Spring Boot auto-configuration                             -->
    <!-- ================================================================== -->
    <Match>
        <Class name="~.*AutoConfiguration"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Record Types: EI_EXPOSE_REP / EI_EXPOSE_REP2                       -->
    <!-- Record constructors and getters inherently expose internal state   -->
    <!-- when fields are mutable objects (List, AtomicReference, etc.)      -->
    <!-- This is by design - Records are immutable containers               -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Result"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Stats"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Config"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Entry"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Info"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Definition"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Snapshot"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*State"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
        <Class name="~com\.aurora\.core\..*\$.*Event"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Result"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Stats"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Config"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Entry"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Info"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Definition"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Snapshot"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*State"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\..*\$.*Event"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Spring Dependency Injection: URF_UNREAD_FIELD                        -->
    <!-- Spring injects fields via @Autowired/@Value that may appear unread   -->
    <!-- in static analysis but are used by the framework at runtime          -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Class name="~com\.aurora\.core\.adapter\..*"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Class name="~com\.aurora\.core\.application\..*"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Class name="~com\.aurora\.core\.infrastructure\..*"/>
    </Match>
    <Match>
        <Bug pattern="URF_UNREAD_FIELD"/>
        <Class name="~com\.aurora\.core\.ai\..*"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Spring Boot Controller Constructors: EI_EXPOSE_REP2                  -->
    <!-- Controllers receive Spring-managed beans via constructor injection   -->
    <!-- These are singletons managed by Spring, not external mutable state   -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\.adapter\.web\..*Controller"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\.adapter\.mcp\..*"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Service/Component Constructors: EI_EXPOSE_REP2                     -->
    <!-- Service constructors receive injected dependencies                   -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\.application\..*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\.ai\..*"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Infrastructure Classes: EI_EXPOSE_REP2                             -->
    <!-- Config classes, filters, interceptors receive injected dependencies  -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Class name="~com\.aurora\.core\.infrastructure\..*"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Common False Positives in Validators and Parsers                   -->
    <!-- ================================================================== -->
    <!-- Redundant null checks: often defensive programming                 -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
        <Class name="~com\.aurora\.core\..*"/>
    </Match>

    <!-- Dead local store: common in parser/loader code with early returns   -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
        <Class name="~com\.aurora\.core\.application\.SkillDefinitionLoader"/>
    </Match>

    <!-- Catch Exception: common in validators, converters, parsers         -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
        <Class name="~com\.aurora\.core\.ai\.JsonSchemaValidator"/>
    </Match>

    <!-- ================================================================== -->
    <!-- Useless void method: rollback() is a design pattern                -->
    <!-- ================================================================== -->
    <Match>
        <Bug pattern="UC_USELESS_VOID_METHOD"/>
        <Class name="~com\.aurora\.core\.application\.AIPipelineOrchestrator"/>
        <Method name="rollback"/>
    </Match>

</FindBugsFilter>
