    <!-- ========================================================== -->
    <!-- 8. Kotlin Stdlib 误报                                       -->
    <!--    CVE-2020-29582 针对 Kotlin &lt; 1.4.21，不适用于 1.9.25   -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            False positive: CVE-2020-29582 affects Kotlin versions before 1.4.21.
            Current version is 1.9.25. NVD CPE matching is incorrect.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-stdlib.*@1\.9\.25.*$</packageUrl>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <!-- ========================================================== -->
    <!-- 9. Log4j API 误报                                           -->
    <!--    CVE-2025-68161 影响的是 log4j-core，不是 log4j-api      -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            False positive: CVE-2025-68161 affects log4j-core, not log4j-api.
            This project only uses log4j-api (via SLF4J).
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-api@2\.24\.3.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- ========================================================== -->
    <!-- 10. OpenTelemetry Semantic Conventions 误报                 -->
    <!--    CPE 匹配错误：semconv 库 vs opentelemetry 收集器        -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            False positive: opentelemetry-semconv (semantic conventions library)
            incorrectly matched to opentelemetry collector CPE.
            CVE-2026-39882/39883 do not apply to this library.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry\.semconv/opentelemetry-semconv@1\.32\.0.*$</packageUrl>
        <cve>CVE-2026-39882</cve>
        <cve>CVE-2026-39883</cve>
    </suppress>

    <!-- ========================================================== -->
    <!-- 11. Swagger UI 内嵌 DOMPurify 误报                          -->
    <!--    客户端 XSS，不影响后端服务                               -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            Swagger UI bundles DOMPurify for client-side use. These CVEs are for
            browser-side XSS vulnerabilities and do not affect this backend service.
            The Swagger UI is only used for API documentation in development.
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@.*$</packageUrl>
        <cve>CVE-2025-26791</cve>
        <cve>CVE-2025-15599</cve>
        <cve>CVE-2026-0540</cve>
        <cve>CVE-2026-41240</cve>
        <cve>CVE-2026-41238</cve>
        <cve>CVE-2026-41239</cve>
    </suppress>

