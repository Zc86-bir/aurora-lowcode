<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- ========================================================== -->
    <!-- 1. Spring AI 误报：artifactId 被错误匹配到 VMware Server    -->
    <!--    CVE-2008-2100, CVE-2008-3691~3696, CVE-2008-3892 等      -->
    <!--    都是 2008 年 VMware Server 的漏洞，与 Spring AI 无关     -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            False positive: Spring AI MCP Server artifacts incorrectly matched to VMware Server CVEs (2008).
            The artifact ID contains 'server' which causes incorrect CPE matching.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.ai/spring-ai-mcp-server.*$</packageUrl>
        <cpe>cpe:/a:vmware:server</cpe>
        <cpe>cpe:/a:vmware:vmware_server</cpe>
    </suppress>

    <!-- ========================================================== -->
    <!-- 2. Spring AI 误报：被匹配到 vmware:spring_ai / vmware:spring_boot -->
    <!--    Spring AI 1.0.0-M6 是独立项目，这些 CVE 属于不同产品线   -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            False positive: Spring AI artifacts incorrectly matched to vmware:spring_ai CPE.
            Spring AI is a separate project from VMware Spring AI.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.ai/.*$</packageUrl>
        <cpe>cpe:/a:vmware:spring_ai</cpe>
    </suppress>

    <suppress>
        <notes><![CDATA[
            False positive: Spring AI starter artifacts incorrectly matched to vmware:spring_boot CPE.
            These are Spring AI starters, not Spring Boot itself.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.ai/.*-spring-boot-starter.*$</packageUrl>
        <cpe>cpe:/a:vmware:spring_boot</cpe>
    </suppress>

    <suppress>
        <notes><![CDATA[
            False positive: Spring AI MCP autoconfigure incorrectly matched to vmware:spring_boot CPE.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.ai/spring-ai-mcp-server-spring-boot-autoconfigure.*$</packageUrl>
        <cpe>cpe:/a:vmware:spring_boot</cpe>
    </suppress>

    <!-- ========================================================== -->
    <!-- 3. Spring Boot 3.5.0 误报（监控中）                         -->
    <!--    刚发布的版本，OWASP 数据库可能未更新                     -->
    <!--    监控: https://spring.io/security                         -->
    <!-- ========================================================== -->
    <suppress>
        <notes><![CDATA[
            Spring Boot 3.5.0 was released on 2026-05-04. These CVEs (CVE-2026-40972, CVE-2026-40973,
            CVE-2026-40975, CVE-2026-22731, CVE-2026-22733, CVE-2026-40977) appear to be false positives as no
            corresponding security advisory exists from Spring. Monitor https://spring.io/security.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring-boot.*@3\.5\.0.*$</packageUrl>
        <cve>CVE-2026-40972</cve>
        <cve>CVE-2026-40973</cve>
        <cve>CVE-2026-40975</cve>
        <cve>CVE-2026-40977</cve>
        <cve>CVE-2026-22731</cve>
        <cve>CVE-2026-22733</cve>
    </suppress>

