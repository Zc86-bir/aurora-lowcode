# Caddy Production Configuration for Aurora Frontend
#
# This config provides production-grade caching for Vite 6 build artifacts.
# Place this as Caddyfile in your deployment directory.
#
# Cache Strategy:
# - /index.html → NO cache (ensures instant updates on deploy)
# - /assets/**  → IMMUTABLE cache (365 days, assets have content hash)
# - /static/**  → LONG cache (1 day, non-hashed static files)
# - /favicon.ico → LONG cache (1 day)

{
	http_port 80
	admin off
}

:80 {
	# Security headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https:;"
	}

	# Gzip compression
	encode gzip

	# Frontend static files
	root * /usr/share/caddy

	# HTML entry point — NO cache, ensures instant updates on deploy
	@indexHtml path /index.html
	header @indexHtml {
		Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "0"
	}

	# Service worker — NO cache (critical for PWA updates)
	@sw path /sw.js /service-worker.js
	header @sw {
		Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
		Pragma "no-cache"
		Expires "0"
	}

	# Static assets with hash fingerprint — IMMUTABLE cache (365 days)
	# Vite 6 generates: /assets/index-D8gR1.js, /assets/index-Ck2sL.css
	@assets path /assets/*
	header @assets {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# Static files without hash — SHORT cache (1 day)
	@static path /static/*
	header @static {
		Cache-Control "public, max-age=86400"
	}

	# Favicon — SHORT cache (1 day)
	@favicon path /favicon.ico
	header @favicon {
		Cache-Control "public, max-age=86400"
	}

	# Fonts — LONG cache (30 days)
	@fonts path *.woff *.woff2 *.ttf *.otf *.eot
	header @fonts {
		Cache-Control "public, max-age=2592000"
	}

	# Images — MEDIUM cache (7 days)
	@images path *.png *.jpg *.jpeg *.gif *.ico *.svg *.webp *.avif
	header @images {
		Cache-Control "public, max-age=604800"
	}

	# SPA Fallback
	try_files {path} {path}/ /index.html

	# API Proxy (backend)
	@api path /api/*
	reverse_proxy @api 127.0.0.1:8080 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Tenant-Id {header.X-Tenant-Id}
		header_up X-User-Id {header.X-User-Id}
		header_down Cache-Control "no-store"
	}

	# Health Check
	@health path /healthz
	respond @health "OK" 200

	# Client body size limit
	request_body {
		max_size 50m
	}

	# Logging
	log {
		format json
	}
}
